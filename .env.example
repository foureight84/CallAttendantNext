# =============================================================================
# REQUIRED — application will not function correctly without these set
# =============================================================================

# Path to the USB modem device.
# Linux: /dev/ttyUSB0 or /dev/ttyACM0
# macOS: /dev/tty.usbmodem* (use tty.* not cu.*)
# Windows: COM3 (check Device Manager)
SERIAL_PORT=/dev/tty.usbmodem00000021

# Baud rate for the modem serial connection.
# 57600  — USR 5637
# 115200 — MultiTech MT9234MU-CDC, Conexant, ZOOM 3095
SERIAL_BAUD_RATE=115200

# Path to the piper TTS binary.
# Baremetal: set to the local binary path.
# Docker: piper is pre-installed globally — leave this as-is or unset.
PIPER_BINARY=./piper/piper

# Directory containing .onnx voice model files (scanned automatically at startup).
# Each model must have a companion .onnx.json file for sample rate detection.
PIPER_MODELS_DIR=./piper-models

# =============================================================================
# OPTIONAL — safe defaults are used when not set
# =============================================================================

# ─── Database & Storage ───────────────────────────────────────────────────────

# Path to the SQLite database file. Do not change.
# DB_PATH=./callattendant.db

# Directory where voicemail MP3 files are saved. Do not change.
# MESSAGES_DIR=./messages

# HTTP port the web UI listens on (default: 3000).
# PORT=3000

# ─── Call Screening ───────────────────────────────────────────────────────────

# Comma-separated list of active screening modes.
# whitelist — permit known callers immediately
# blacklist — block known spam callers
# Both enabled: blacklist checked first, then whitelist, then Nomorobo.
# SCREENING_MODE=whitelist,blacklist

# Spam lookup service used for unknown callers.
# NOMOROBO — query nomorobo.com (free, US/Canada robocall database)
# NONE      — skip external lookup, send all unknown callers to voicemail
# BLOCK_SERVICE=NOMOROBO

# Nomorobo score threshold at or above which a caller is blocked.
# 1 = suspicious, 2 = known robocall/scam (recommended)
# SPAM_THRESHOLD=2

# Automatically add callers to the blocklist when they meet SPAM_THRESHOLD.
# true (default) | false
# AUTO_BLOCK_SPAM=true

# Automatically re-verify blocklist entries added with "Robocall" as the reason against Nomorobo.
# Numbers that are no longer flagged are removed. Disabled by default.
# ROBOCALL_CLEANUP_ENABLED=false

# Cron schedule for the robocall cleanup job (standard 5-field cron syntax).
# Default: Saturday at 2:00 AM. Only used when ROBOCALL_CLEANUP_ENABLED=true.
# ROBOCALL_CLEANUP_CRON=0 2 * * 6

# ─── Call Handling ────────────────────────────────────────────────────────────

# Number of rings to wait before going to voicemail for whitelisted callers.
# RINGS_BEFORE_VM=4

# Number of rings to wait before going to voicemail for screened (unknown) callers.
# RINGS_BEFORE_VM_SCREENED=1

# Action taken for blacklisted callers.
# 1 — hang up silently
# 2 — play blocked greeting then hang up (default)
# 3 — send to voicemail after RINGS_BEFORE_VM_BLOCKLIST rings
# BLOCKLIST_ACTION=2

# Rings to wait before sending a blacklisted caller to voicemail (BLOCKLIST_ACTION=3 only).
# RINGS_BEFORE_VM_BLOCKLIST=0

# Send a DTMF key to blocked callers per the FCC opt-out rule. Disabled by default.
# DTMF_REMOVAL_ENABLED=false

# The DTMF key to send when DTMF_REMOVAL_ENABLED=true. Most commonly 9 (default).
# Valid values: 0-9, *, #
# DTMF_REMOVAL_KEY=9

# ─── TTS (Piper) ──────────────────────────────────────────────────────────────

# Speech speed multiplier. 1.0 = normal speed. Higher values = slower speech.
# Recommended range: 1.0–1.5
# PIPER_LENGTH_SCALE=1.0

# ─── Logging ──────────────────────────────────────────────────────────────────

# Path to the modem log file.
# LOG_FILE=./logs/modem.log

# Rotate the log file when it exceeds this size in bytes (default: 5242880 = 5 MB).
# LOG_MAX_BYTES=5242880

# Number of rotated log files to keep before deleting the oldest.
# LOG_KEEP_FILES=2

# ─── Email Notifications ──────────────────────────────────────────────────────

# Set to true to enable email notifications.
# EMAIL_ENABLED=false

# SMTP server hostname.
# EMAIL_HOST=smtp.example.com

# SMTP server port. 587 = STARTTLS (recommended), 465 = SSL, 25 = plain.
# EMAIL_PORT=587

# SMTP login credentials.
# EMAIL_USER=user@example.com
# EMAIL_PASS=your-smtp-password

# Sender address shown in the From field.
# EMAIL_FROM=callattendant@example.com

# Recipient address for all notification emails.
# EMAIL_TO=you@example.com

# Send an email when a voicemail is saved (default: true).
# EMAIL_NOTIFY_VOICEMAIL=true

# Send an email when a call is blocked (default: false).
# EMAIL_NOTIFY_BLOCKED=false

# Send an email for every call regardless of outcome (default: false).
# EMAIL_NOTIFY_ALL=false

# ─── MQTT Notifications ───────────────────────────────────────────────────────

# Set to true to enable MQTT notifications.
# MQTT_ENABLED=false

# MQTT broker URL (e.g. mqtt://192.168.1.10:1883 or mqtts://broker.example.com).
# MQTT_BROKER_URL=mqtt://localhost:1883

# MQTT broker credentials (leave blank if not required).
# MQTT_USERNAME=
# MQTT_PASSWORD=

# Topic prefix for all published messages.
# Messages are published to {prefix}/calls and {prefix}/voicemail.
# MQTT_TOPIC_PREFIX=callattendant

# Publish an MQTT message when a voicemail is saved (default: true).
# MQTT_NOTIFY_VOICEMAIL=true

# Publish an MQTT message when a call is blocked (default: true).
# MQTT_NOTIFY_BLOCKED=true

# Publish an MQTT message for every call regardless of outcome (default: false).
# MQTT_NOTIFY_ALL=false

# ─── Advanced / Debug ─────────────────────────────────────────────────────────

# Enable the /debug page in the web UI (default: false).
# DEBUG_CONSOLE=false

# Enable diagnostic mode — runs modem detection and capability queries on startup
# and logs the results. Useful when setting up a new modem (default: false).
# DIAGNOSTIC_MODE=false

# Save raw PCM audio alongside each voicemail MP3 for debugging recording issues.
# Files are saved to MESSAGES_DIR with a .pcm extension (default: false).
# SAVE_PCM_DEBUG=false

# Enable GPIO output for Raspberry Pi LED indicators (default: false).
# Requires the 'onoff' package and appropriate GPIO pin wiring.
# ENABLE_GPIO=false
