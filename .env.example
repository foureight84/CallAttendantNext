SERIAL_PORT=/dev/ttyUSB0 #change to your modem path (Windows: COM3, etc, check Device Manager), MacOS use /dev/tty.* instead of /dev/cu.*
SERIAL_BAUD_RATE=57600 #keep this value unless your modem allows for higher baud rate
DB_PATH=./callattendant.db #DO NOT change this
MESSAGES_DIR=./messages #DO NOT change this
SCREENING_MODE=whitelist,blacklist
BLOCK_SERVICE=NOMOROBO
# SPAM_THRESHOLD: 1=new category we haven't seen yet. 2=any in this list ['Robocall', 'Telemarketer', 'Political', 'Scam', 'Debt Collector', 'Do Not Answer'], 3=currently not implemented
SPAM_THRESHOLD=2
RINGS_BEFORE_VM=4 #numbers in phonebook/whitelist
RINGS_BEFORE_VM_SCREENED=2 #numbers not in phonebook/whitelist or blocklist/blacklist
# BLOCKLIST_ACTION: 1=hang up silently, 2=play blocked greeting then hang up, 3=send to voicemail after N rings
BLOCKLIST_ACTION=2
RINGS_BEFORE_VM_BLOCKLIST=0 #used with BLOCKLIST_ACTION=3, sets number of rings before VM
ENABLE_GPIO=false #Raspberry Pi users only (untested)
# DEBUG_CONSOLE: set to true to enable the Debug Console page
DEBUG_CONSOLE=false
# PIPER_BINARY: path to the piper TTS binary
PIPER_BINARY=piper
# PIPER_MODELS_DIR: directory containing .onnx model files (scanned automatically)
# Sample rate is read from each model's companion .onnx.json file automatically.
PIPER_MODELS_DIR=./piper-models
# PIPER_LENGTH_SCALE: speech speed multiplier (1.0 = normal, higher = slower). Range: 1.000–1.500
PIPER_LENGTH_SCALE=1.0
# LOG_FILE: path to modem log file (default: ./logs/modem.log)
# LOG_FILE=./logs/modem.log
# LOG_MAX_BYTES: rotate log when it exceeds this size in bytes (default: 5242880 = 5MB)
# LOG_MAX_BYTES=5242880
# LOG_KEEP_FILES: number of rotated log files to keep (default: 2)
# LOG_KEEP_FILES=2
